<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <link rel="icon" type="image/png" href="/galaxyswap-logo.png" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Galaxyswap | Midnight DEX</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=IBM+Plex+Mono:wght@400;500;600&family=IBM+Plex+Sans:wght@400;500;600;700&family=Plus+Jakarta+Sans:wght@600;700&display=swap"
      rel="stylesheet"
    />
    <style>
      :root {
        color-scheme: dark;
      }

      body {
        margin: 0;
        min-width: 320px;
        background:
          radial-gradient(ellipse 55% 50% at 10% 10%, hsl(44 88% 64% / 0.16) 0%, transparent 55%),
          radial-gradient(ellipse 50% 45% at 88% 8%, hsl(194 84% 66% / 0.16) 0%, transparent 55%),
          radial-gradient(ellipse 60% 55% at 50% 48%, hsl(28 76% 70% / 0.11) 0%, transparent 60%),
          radial-gradient(ellipse 45% 40% at 92% 50%, hsl(332 74% 72% / 0.12) 0%, transparent 50%),
          radial-gradient(ellipse 55% 50% at 8% 88%, hsl(274 70% 74% / 0.12) 0%, transparent 55%),
          radial-gradient(ellipse 50% 45% at 82% 92%, hsl(196 82% 66% / 0.12) 0%, transparent 50%),
          hsl(222 25% 10%);
        color: hsl(210 20% 96%);
        font-family: "IBM Plex Sans", "Avenir Next", "Segoe UI", sans-serif;
      }

      #root {
        min-height: 100vh;
      }

      #app-boot-splash {
        position: fixed;
        inset: 0;
        z-index: 9999;
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 24px;
        background:
          linear-gradient(180deg, hsl(222 25% 10% / 0.82), hsl(222 25% 10% / 0.92));
        opacity: 1;
        visibility: visible;
        transition: opacity 220ms ease, visibility 220ms ease;
      }

      #app-boot-splash[data-hidden="true"] {
        opacity: 0;
        visibility: hidden;
        pointer-events: none;
      }

      .boot-splash__card {
        width: min(100%, 320px);
        border: 1px solid hsl(218 18% 28% / 0.7);
        border-radius: 24px;
        padding: 28px 24px;
        background:
          radial-gradient(120% 100% at 0% 0%, hsl(44 88% 68% / 0.08), transparent 58%),
          radial-gradient(120% 100% at 100% 0%, hsl(194 84% 66% / 0.08), transparent 60%),
          hsl(222 24% 12% / 0.92);
        box-shadow:
          0 0 0 1px hsl(0 0% 100% / 0.05) inset,
          0 24px 62px -20px hsl(222 35% 4% / 0.68);
        text-align: center;
        backdrop-filter: blur(18px);
        -webkit-backdrop-filter: blur(18px);
      }

      .boot-splash__logo-wrap {
        position: relative;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        width: 84px;
        height: 84px;
        margin-bottom: 18px;
      }

      .boot-splash__halo,
      .boot-splash__ring {
        position: absolute;
        inset: 0;
        border-radius: 999px;
      }

      .boot-splash__halo {
        background:
          radial-gradient(circle, hsl(194 84% 66% / 0.34) 0%, transparent 68%);
        filter: blur(10px);
        animation: boot-pulse 2.2s ease-in-out infinite;
      }

      .boot-splash__ring {
        inset: 8px;
        border: 2px solid hsl(194 84% 66% / 0.22);
        border-top-color: hsl(44 88% 68% / 0.88);
        border-right-color: hsl(194 84% 66% / 0.72);
        animation: boot-spin 1.1s linear infinite;
      }

      .boot-splash__logo {
        position: relative;
        width: 44px;
        height: 44px;
        object-fit: contain;
        filter:
          drop-shadow(0 8px 20px hsl(222 32% 4% / 0.48))
          drop-shadow(0 0 12px hsl(194 84% 66% / 0.18));
      }

      .boot-splash__title {
        margin: 0;
        font-family: "Plus Jakarta Sans", "IBM Plex Sans", sans-serif;
        font-size: 1.05rem;
        font-weight: 700;
        letter-spacing: -0.02em;
      }

      .boot-splash__subtitle {
        margin: 8px 0 0;
        color: hsl(218 14% 70%);
        font-size: 0.92rem;
        line-height: 1.5;
      }

      .boot-splash__dots {
        display: inline-flex;
        gap: 6px;
        margin-top: 18px;
      }

      .boot-splash__dot {
        width: 8px;
        height: 8px;
        border-radius: 999px;
        background: hsl(210 20% 96% / 0.32);
        animation: boot-dot 1.3s ease-in-out infinite;
      }

      .boot-splash__dot:nth-child(2) {
        animation-delay: 120ms;
      }

      .boot-splash__dot:nth-child(3) {
        animation-delay: 240ms;
      }

      @keyframes boot-spin {
        to {
          transform: rotate(360deg);
        }
      }

      @keyframes boot-pulse {
        0%, 100% {
          opacity: 0.55;
          transform: scale(0.96);
        }

        50% {
          opacity: 1;
          transform: scale(1.06);
        }
      }

      @keyframes boot-dot {
        0%, 80%, 100% {
          opacity: 0.28;
          transform: translateY(0);
        }

        40% {
          opacity: 1;
          transform: translateY(-3px);
        }
      }

      @media (prefers-reduced-motion: reduce) {
        #app-boot-splash,
        .boot-splash__halo,
        .boot-splash__ring,
        .boot-splash__dot {
          animation: none;
          transition: none;
        }
      }
    </style>
    <script type="module" crossorigin src="/assets/index-BEp7oJNQ.js"></script>
    <link rel="stylesheet" crossorigin href="/assets/index-EK6e8zfa.css">
  </head>
  <body>
    <div id="app-boot-splash" role="status" aria-live="polite" aria-label="Loading GalaxySwap">
      <div class="boot-splash__card">
        <div class="boot-splash__logo-wrap" aria-hidden="true">
          <div class="boot-splash__halo"></div>
          <div class="boot-splash__ring"></div>
          <img class="boot-splash__logo" src="/galaxyswap-logo.png" alt="" />
        </div>
        <p class="boot-splash__title">Loading GalaxySwap</p>
        <p class="boot-splash__subtitle">Preparing wallets, markets, and Midnight liquidity.</p>
        <div class="boot-splash__dots" aria-hidden="true">
          <span class="boot-splash__dot"></span>
          <span class="boot-splash__dot"></span>
          <span class="boot-splash__dot"></span>
        </div>
      </div>
    </div>
    <div id="root"></div>
  </body>
  </html>
